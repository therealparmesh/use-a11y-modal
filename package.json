{
  "name": "use-a11y-modal",
  "version": "0.7.0",
  "description": "Small, accessible React modal hook with focus and inert background management.",
  "license": "MIT",
  "author": "Parmesh Krishen",
  "repository": "github:therealparmesh/use-a11y-modal",
  "files": [
    "src/index.js",
    "types.d.ts"
  ],
  "type": "module",
  "main": "./src/index.js",
  "types": "./types.d.ts",
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "import": "./src/index.js"
    }
  },
  "scripts": {
    "format": "bunx oxfmt .",
    "prepack": "bun run test",
    "release": "bunx standard-version",
    "test": "bun test --coverage"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "packageManager": "bun@1.3.14",
  "standard-version": {
    "releaseCommitMessageFormat": "chore: release {{currentTag}}",
    "scripts": {
      "postchangelog": "bunx oxfmt CHANGELOG.md"
    }
  }
}
